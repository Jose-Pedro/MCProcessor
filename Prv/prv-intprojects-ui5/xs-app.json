{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/odata/v2/service/(.*)$",
      "target": "/odata/v2/service/$1",
      "destination": "Agora-prvintprojects-HTTP",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^/CmmOpentextSrv/(.*)$",
      "target": "$1",
      "csrfProtection": false,
      "destination": "Agora-CmmOpenText-HTTP",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/v2/restriction/(.*)$",
      "target": "/v2/restriction/$1",
      "destination": "Agora-AccService-HTTP",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
