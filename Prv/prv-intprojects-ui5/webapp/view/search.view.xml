<mvc:View controllerName="prvintprojectsui5.controller.search"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:table="sap.ui.table" 
    xmlns:smartTable="sap.ui.comp.smarttable" 
    xmlns:smartfilterbar="sap.ui.comp.smartfilterbar"
    xmlns="sap.m" 
    xmlns:f="sap.f"
    xmlns:customdata="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
   
    displayBlock="true">
    <f:DynamicPage id="page" headerPinned="true" toggleHeaderOnTitleClick="false" >
		<f:title>
			<f:DynamicPageTitle id="_IDGenDynamicPageTitle">
				<f:heading>
					<Title id="_IDGenTitle" text="{i18n>title}" wrapping="true" />
				</f:heading>
                <f:actions>
                    <MenuButton id="createRequestMenuButton" text="{i18n>createRequest}" type="Emphasized" useDefaultActionOnly="true" defaultAction="oncreateRequestMenu" visible="{configuration>/requestActions/create}">
                        <menu>
                            <Menu id="_IDGenMenu">
                            </Menu>
                        </menu>
                    </MenuButton>
				</f:actions>
			</f:DynamicPageTitle>
		</f:title>
	    <f:header>
			<f:DynamicPageHeader id="_IDGenDynamicPageHeader" pinnable="true">
				<VBox id="_IDGenVBox">
					<IconTabBar id="_IDGenIconTabBar" backgroundDesign="Transparent" headerBackgroundDesign="Transparent" class="sapUiNoContentPadding" expandable="false" selectedKey="{viewModel>/selectedTabKey}" >
                        <items>
                            <IconTabFilter id="searchByRequests" key="searchByRequests" text="{i18n>searchByRequests}" design="Horizontal" >
                                <smartfilterbar:SmartFilterBar id="searchByRequestsFilter" class="sapContrastPlus" persistencyKey="searchByRequestsFilter" filterBarExpanded="true" showGoOnFB="true" showClearOnFB="true" entitySet="SearchByRequests">
                                    <smartfilterbar:controlConfiguration>
                                        <smartfilterbar:ControlConfiguration id="requestRequestedDate" key="requestedDate" visibleInAdvancedArea="false" conditionType="{ 
                                            module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>requestedDate}" />
                                        <smartfilterbar:ControlConfiguration id="requestAssignationDate" key="assignationDate" visibleInAdvancedArea="true" conditionType="{
            								module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>assignationDate}" />
                                        <smartfilterbar:ControlConfiguration id="requestCreatedAt" key="createdAt" visibleInAdvancedArea="true" conditionType="{
            								module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>createdAt}" />
                                    </smartfilterbar:controlConfiguration>
                                </smartfilterbar:SmartFilterBar>
                            </IconTabFilter>
                            <IconTabFilter id="searchByTasks"  key="searchByTasks" text="{i18n>searchByTasks}" design="Horizontal" >
                                <smartfilterbar:SmartFilterBar id="searchByTasksFilter" class="sapContrastPlus" persistencyKey="searchByTasksFilter" filterBarExpanded="true" showGoOnFB="true" showClearOnFB="true" entitySet="SearchByTasks">
                                    <smartfilterbar:controlConfiguration>
                                        <smartfilterbar:ControlConfiguration id="taskRequestedDate" key="requestedDate" visibleInAdvancedArea="false" conditionType="{ 
                                            module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>requestedDate}" />
                                        <smartfilterbar:ControlConfiguration id="taskAssignationDate" key="assignationDate" visibleInAdvancedArea="true" conditionType="{
            								module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>assignationDate}" />
                                        <smartfilterbar:ControlConfiguration id="taskCreatedAt" key="createdAt" visibleInAdvancedArea="true" conditionType="{
            								module: 'sap.ui.comp.config.condition.DateRangeType' }" label="{i18n>createdAt}" />
                                    </smartfilterbar:controlConfiguration>
                                </smartfilterbar:SmartFilterBar>
                            </IconTabFilter>                            
                        </items>
                    </IconTabBar>
				</VBox>
			</f:DynamicPageHeader>
		</f:header>
        <f:content>
            <VBox id="_IDGenVBox1" height="100%">
                <smartTable:SmartTable 
                    id="searchByRequestsTable" 
                    entitySet="SearchByRequests" 
                    width="100%" 
                    direction="Column" 
                    fitContainer="true" 
                    enableAutoBinding="true" 
                    placeToolbarInTable="true" 
                    persistencyKey="searchByRequestsTable" 
                    smartFilterId="searchByRequestsFilter" 
                    header="{i18n>requests}"
                    enableAutoColumnWidth="true" 
                    customizeConfig="{'autoColumnWidth': {'*': {'min': 5, 'max': 7, 'gap': 0, 'truncateLabel': false}}}"
                    requestAtLeastFields="ID,projectTypeName,projectObjectiveName,statusName,siteName,cellnexZoneName,managerName,preferredProviderName,objectStatus"
                    visible="{= ${viewModel>/selectedTabKey} === 'searchByRequests' }">
                    <table:Table id="searchByRequestsInnerTable" cellClick="onCellCliked" >
                        <table:contextMenu>
                        </table:contextMenu>
                    </table:Table >
                </smartTable:SmartTable>  
                <smartTable:SmartTable 
                    id="searchByTasksTable" 
                    entitySet="SearchByTasks" 
                    width="100%" 
                    direction="Column" 
                    fitContainer="true" 
                    enableAutoBinding="true" 
                    placeToolbarInTable="true" 
                    persistencyKey="searchByTasksTable" 
                    smartFilterId="searchByTasksFilter" 
                    header="{i18n>tasks}"
                    enableAutoColumnWidth="true" 
                    customizeConfig="{'autoColumnWidth': {'*': {'min': 5, 'max': 7, 'gap': 0, 'truncateLabel': false}}}"
                    requestAtLeastFields="ID,projectTypeName,projectObjectiveName,requestStatusName,statusName,siteName,cellnexZoneName,assignedResponsibleName,managerName,preferredProviderName,taskTypeName,documentName,objectStatus,objectRequestStatus,masterPhaseId,masterBlockID,lastBlockName,lastPhaseName,isFirstBlockName,workId,workTypeName,roleId"
                    visible="{= ${viewModel>/selectedTabKey} === 'searchByTasks' }">
                    <table:Table id="searchByTasksInnerTable" cellClick="onCellCliked" >
                        <table:contextMenu>
                        </table:contextMenu>
                    </table:Table>
                </smartTable:SmartTable>      
            </VBox>
    	</f:content>
        <f:footer>
            <OverflowToolbar id="footerToolbar" visible="{= ${viewModel>/selectedTabKey} === 'multiEditHeader' || ${viewModel>/selectedTabKey} === 'multiEditBlock' }">
                <Button id="showMessagesMultiEdit" icon="sap-icon://message-popup" text="{= ${message>/}.length }" type="Neutral" press="onMessagePopoverPressMultiEdit"/>
                <ToolbarSpacer id="_IDGenToolbarSpacer" />
                <Button visible="{= ${viewModel>/selectedTabKey} === 'multiEditHeader'}" text="{i18n>save}" press="onSaveChangesSmartTableMultiEditHeader" type="Emphasized" enabled="{= ${viewModel>/selectedRowsCount} > 0}" id="saveMultinputHeader"/>
                <Button visible="{= ${viewModel>/selectedTabKey} === 'multiEditBlock'}" text="{i18n>save}" press="onSaveChangesSmartTableMultiEditBlocks" type="Emphasized" enabled="{= ${viewModel>/selectedRowsCountBlocks} > 0}" id="saveMultinputBlock"  />
            </OverflowToolbar>
        </f:footer>
	</f:DynamicPage>
</mvc:View>
