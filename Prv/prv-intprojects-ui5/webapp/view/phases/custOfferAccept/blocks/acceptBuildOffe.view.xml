<mvc:View
    controllerName="prvintprojectsui5.controller.phases.custOfferAccept.blocks.acceptBuildOffe"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:upload="sap.m.upload"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:layout="sap.ui.layout" 
    xmlns:table="sap.ui.table"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"  
    displayBlock="true">

    <Panel width="auto" visible="{=${configuration>/processInfo/custOfferAccept/acceptBuildOffe/VISIBLE_ON} === 'X'}" expandable="true" expanded="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS}}" id="acceptBuildOffePanel" class="sapUiResponsiveMargin">
        <headerToolbar>
            <OverflowToolbar id="acceptBuildOffeToolbar" design="Transparent" class="sapMShowEmpty-CTX">
                <Title id="acceptBuildOffeTitle" text="{i18n>acceptBuildOffe}"/>
                <ToolbarSpacer id="acceptBuildOffe_IDGenToolbarSpacer3"/>
                <smartfield:SmartLabel id="acceptBuildOffe_IDGenSmartLabel" labelFor="selectAssignedResponsible"/>
                <smartfield:SmartField id="selectAssignedResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/assignedResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="acceptBuildOffe_IDGenSmartLabel1" labelFor="selectSucontractorResponsible"/>
                <smartfield:SmartField id="selectSucontractorResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/subcontractorType}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onSubcoTypeChange"/>
                <smartfield:SmartLabel id="acceptBuildOffe_IDGenSmartLabel2" labelFor="selectExternalResponsible"/>
                <smartfield:SmartField id="selectExternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/externalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="acceptBuildOffe_IDGenSmartLabel3" labelFor="selectInternalResponsible"/>
                <smartfield:SmartField id="selectInternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/internalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" textInEditModeSource="ValueListNoValidation"/>
                <ToolbarSpacer id="acceptBuildOffe_IDGenToolbarSpacer5"/>
                <Switch id="acceptBuildOffe_IDGenSwitch"  customTextOn=" " customTextOff=" "  state="{activated}" visible="{= ${mandatory} !== 'X'}" change="onActiveChange" enabled="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/custOfferAccept/acceptBuildOffe/activate} === true }"/>
                <Button id="closeBlockacceptBuildOffe" press="onCloseBlock" text="{i18n>complete}" visible="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/custOfferAccept/acceptBuildOffe/complete} === true}"/>
                <OverflowToolbarButton id="buttonacceptBuildOffeForm" press="onEditBlock" icon="sap-icon://edit" enabled="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}"  visible="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/custOfferAccept/acceptBuildOffe/reopen} === true}"/>
                <ObjectStatus id="acceptBuildOffe_IDGenObjectStatus1" text="{BlockStatus/name}" state="{path: 'status', formatter:'.statusStateFormatter'}" icon="{path:'status', formatter: '.statusIconFormatter' }"/>                
            </OverflowToolbar>
        </headerToolbar>
        <content>
            <smartform:SmartForm id="acceptBuildOffeForm" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}">
                <smartform:layout>
                    <smartform:ColumnLayout id="acceptBuildOffe_IDGenColumnLayout1" columnsM="2" columnsL="3" columnsXL="6" labelCellsLarge="2"/>
                </smartform:layout>
                <smartform:groups> 
                    <smartform:Group id="acceptBuildOffe_IDGenGroup1" >
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement12">
                                <smartfield:SmartField id="startDate" value="{openAt}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement13">
                                <smartfield:SmartField id="completedDate" value="{BlockProvision/completedDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement14">
                                <smartfield:SmartField id="completedBy" value="{BlockProvision/completedBy}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement15">
                                <smartfield:SmartField id="totalCostClient" value="{BlockProvision/totalCostClient}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement16">
                                <smartfield:SmartField id="currency" value="{BlockProvision/currency}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement17">
                                <smartfield:SmartField id="accepted" value="{BlockProvision/accepted}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement18">
                                <smartfield:SmartField id="acceptedDate" value="{BlockProvision/acceptedDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_IDGenGroupElement19">
                                <smartfield:SmartField id="rejectionReason" value="{BlockProvision/rejectionReason}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="acceptBuildOffe_sendOfferDate">
                                <smartfield:SmartField id="sendOfferDate" value="{BlockProvision/sendOfferDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                    </smartform:Group>
                </smartform:groups>
            </smartform:SmartForm>
             <smartform:SmartForm editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}" id="acceptBuildOffeCommentsFormForm">
                <smartform:layout>
                    <smartform:ColumnLayout id="acceptBuildOffeCommentsFormFormColumnLayout" columnsM="1" columnsL="1" columnsXL="1" labelCellsLarge="12"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="acceptBuildOffeCommentsFormFormGroup">                
                        <smartform:GroupElement id="acceptBuildOffeCommentsFormFormGroupElement">
                            <smartfield:SmartField id="acceptBuildOffeCommentsConfig" value="{comments}" change="onFieldChange" app:multiLineSettings="{cols: 2000, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group>                
                </smartform:groups>
            </smartform:SmartForm>
            <core:ComponentContainer id="acceptBuildOffeChecklist" usage="checklist"
                name="prvintprojectsui5.components.checklist"
                component="prvintprojectsui5.components.checklist"
                visible="{= ${checklistVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="acceptBuildOffeWorks" usage="works"
                name="prvintprojectsui5.components.works"
                component="prvintprojectsui5.components.works"
                propagateModel="true"
                visible="{= ${worksVisibleVF} === true}"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="acceptBuildOffeApprovalFlow" usage="approvalFlow"
                name="prvintprojectsui5.components.approvalFlow"
                component="prvintprojectsui5.components.approvalFlow"
                visible="{= ${dpbVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="acceptBuildOffeUploadTable" usage="uploadTable"
                name="prvintprojectsui5.components.uploadTable"
                component="prvintprojectsui5.components.uploadTable"
                propagateModel="true"
                height="100%"
                width="100%"  

                >
            </core:ComponentContainer>

        </content>
    </Panel>              
</mvc:View>