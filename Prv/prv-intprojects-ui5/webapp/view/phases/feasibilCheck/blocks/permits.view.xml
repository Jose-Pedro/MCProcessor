<mvc:View 
    id="permits" 
    controllerName="prvintprojectsui5.controller.phases.feasibilCheck.blocks.permits"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core"
    xmlns:customdata="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" 
    xmlns:upload="sap.m.upload"
    xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:table="sap.ui.table"
    displayBlock="true">
    <Panel width="auto" visible="{=${configuration>/processInfo/feasibilCheck/permits/VISIBLE_ON} === 'X'}" expandable="true" expanded="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} }" id="permitsPanel" class="sapUiResponsiveMargin">
        <headerToolbar>
            <OverflowToolbar id="permits_IDGenOverflowToolbar2" design="Transparent" class="sapMShowEmpty-CTX">
                <Title id="permits_IDGenTitle3" text="{i18n>permits}"/>
                <ToolbarSpacer id="permits_IDGenToolbarSpacer4"/>
                <smartfield:SmartLabel id="permits_IDGenSmartLabel" labelFor="selectAssignedResponsible"/>
                <smartfield:SmartField id="selectAssignedResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/assignedResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="permits_IDGenSmartLabel1" labelFor="selectSucontractorResponsible"/>
                <smartfield:SmartField id="selectSucontractorResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/subcontractorType}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onSubcoTypeChange"/>
                <smartfield:SmartLabel id="permits_IDGenSmartLabel2" labelFor="selectExternalResponsible"/>
                <smartfield:SmartField id="selectExternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/externalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="permits_IDGenSmartLabel3" labelFor="selectInternalResponsible"/>
                <smartfield:SmartField id="selectInternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/internalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" textInEditModeSource="ValueListNoValidation"/>
                <ToolbarSpacer id="permits_IDGenToolbarSpacer5"/>
                <Switch id="permits_IDGenSwitch"  customTextOn=" " customTextOff=" "  state="{activated}" visible="{= ${mandatory} !== 'X'}" change="onActiveChange" enabled="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/feasibilCheck/permits/activate} === true }"/>
                <Button id="closeBlock" press="onCloseBlock" text="{i18n>complete}" visible="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/feasibilCheck/permits/complete} === true}"/>
                <OverflowToolbarButton id="buttonpermitsForm" press="onEditBlock" icon="sap-icon://edit" visible="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED}  &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/feasibilCheck/permits/reopen} === true}"/>
                <ObjectStatus id="permits_IDGenObjectStatus2" text="{BlockStatus/name}" state="{path: 'status', formatter:'.statusStateFormatter'}" icon="{path:'status', formatter: '.statusIconFormatter' }"/>                
            </OverflowToolbar>
        </headerToolbar>
        <content>
            <smartform:SmartForm id="permitsForm" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}">
                <smartform:layout>
                    <smartform:ColumnLayout id="permits_IDGenColumnLayout" columnsM="2" columnsL="3" columnsXL="6" labelCellsLarge="2"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="permits_IDGenGroup2">
                            <smartform:GroupElement id="permits_IDGenGroupElement12">
                                    <smartfield:SmartField id="permits_IDstartDate" value="{openAt}" change="onFieldChange"/>
                            </smartform:GroupElement>
                            <smartform:GroupElement id="permits_IDGenGroupElement13">
                                    <smartfield:SmartField id="permits_IDcompletedDate" value="{BlockProvision/completedDate}" change="onFieldChange"/>
                            </smartform:GroupElement>
                            <smartform:GroupElement id="permits_IDGenGroupElement15">
                                    <smartfield:SmartField id="permits_IDcompletedBy" value="{BlockProvision/completedBy}" change="onFieldChange"/>
                            </smartform:GroupElement>
                            <smartform:GroupElement id="permits_IDGenGroupElement16">
                                    <smartfield:SmartField id="permitsFeasibility" value="{BlockProvision/permitsFeasibility}" change="onFieldChange"/>
                            </smartform:GroupElement>
                            <smartform:GroupElement id="permits_IDGenGroupElement17">
                                    <smartfield:SmartField id="permitsFeasibilityExp" value="{BlockProvision/permitsFeasibilityExp}" change="onFieldChange"/>
                            </smartform:GroupElement>                          
                            <smartform:GroupElement id="permits_IDGenGroupElement18">
                                    <smartfield:SmartField id="permitsNeeded" value="{BlockProvision/permitsNeeded}" change="onFieldChange"/>
                            </smartform:GroupElement>                          
                    </smartform:Group>
                </smartform:groups>
            </smartform:SmartForm>
            <smartform:SmartForm editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}" id="permitsCommentsFormForm">
                <smartform:layout>
                    <smartform:ColumnLayout id="permitsCommentsFormFormColumnLayout" columnsM="1" columnsL="1" columnsXL="1" labelCellsLarge="12"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="permitsCommentsFormFormGroup">                
                        <smartform:GroupElement id="permitsCommentsFormFormGroupElement">
                            <smartfield:SmartField id="permitsCommentsConfig" value="{commentsPLU}" change="onFieldChange" customdata:multiLineSettings="{cols: 2000, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group>                
                </smartform:groups>
            </smartform:SmartForm>
            <core:ComponentContainer id="permitsChecklist" usage="checklist"
                name="prvintprojectsui5.components.checklist"
                component="prvintprojectsui5.components.checklist"
                visible="{= ${checklistVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="permitsWorks" usage="works"
                name="prvintprojectsui5.components.works"
                component="prvintprojectsui5.components.works"
                propagateModel="true"
                visible="{= ${worksVisibleVF} === true}"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="permitsApprovalFlow" usage="approvalFlow"
                name="prvintprojectsui5.components.approvalFlow"
                component="prvintprojectsui5.components.approvalFlow"
                visible="{= ${dpbVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="permitsUploadTable" usage="uploadTable"
                name="prvintprojectsui5.components.uploadTable"
                component="prvintprojectsui5.components.uploadTable"
                propagateModel="true"
                height="100%"
                width="100%"  

                >
            </core:ComponentContainer>

        </content>
    </Panel>

</mvc:View>