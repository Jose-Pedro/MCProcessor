<mvc:View
    controllerName="prvintprojectsui5.controller.phases.manageAdapt.blocks.kickOff"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:upload="sap.m.upload"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:layout="sap.ui.layout" 
    xmlns:table="sap.ui.table"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"  
    displayBlock="true">

    <Panel width="auto" visible="{=${configuration>/processInfo/manageAdapt/kickOff/VISIBLE_ON} === 'X'}" expandable="true" expanded="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS}}" id="kickOffPanel" class="sapUiResponsiveMargin">
        <headerToolbar>
            <OverflowToolbar id="kickOffToolbar" design="Transparent" class="sapMShowEmpty-CTX">
                <Title id="kickOffTitle" text="{i18n>kickoff}"/>
                <ToolbarSpacer id="kickOff_IDGenToolbarSpacer3"/>
                <smartfield:SmartLabel id="kickOff_IDGenSmartLabel" labelFor="selectAssignedResponsible"/>
                <smartfield:SmartField id="selectAssignedResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/assignedResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="kickOff_IDGenSmartLabel1" labelFor="selectSucontractorResponsible"/>
                <smartfield:SmartField id="selectSucontractorResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/subcontractorType}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onSubcoTypeChange"/>
                <smartfield:SmartLabel id="kickOff_IDGenSmartLabel2" labelFor="selectExternalResponsible"/>
                <smartfield:SmartField id="selectExternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/externalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="kickOff_IDGenSmartLabel3" labelFor="selectInternalResponsible"/>
                <smartfield:SmartField id="selectInternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/internalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" textInEditModeSource="ValueListNoValidation"/>
                <ToolbarSpacer id="kickOff_IDGenToolbarSpacer5"/>
                <Switch id="kickOff_IDGenSwitch"  customTextOn=" " customTextOff=" "  state="{activated}" visible="{= ${mandatory} !== 'X'}" change="onActiveChange" enabled="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/kickOff/activate} === true }"/>
                <Button id="closeBlockkickOff" press="onCloseBlock" text="{i18n>complete}" visible="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/kickOff/complete} === true}"/>
                <OverflowToolbarButton id="buttonkickOffForm" press="onEditBlock" icon="sap-icon://edit" enabled="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}"  visible="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/kickOff/reopen} === true}"/>
                <ObjectStatus id="kickOff_IDGenObjectStatus1" text="{BlockStatus/name}" state="{path: 'status', formatter:'.statusStateFormatter'}" icon="{path:'status', formatter: '.statusIconFormatter' }"/>                
            </OverflowToolbar>
        </headerToolbar>
        <content>
            <smartform:SmartForm id="kickOffForm" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}">
                <smartform:layout>
                    <smartform:ColumnLayout id="kickOff_IDGenColumnLayout1" columnsM="2" columnsL="3" columnsXL="6" labelCellsLarge="2"/>
                </smartform:layout>
                <smartform:groups> 
                    <smartform:Group id="kickOff_IDGenGroup1" >
                        <smartform:GroupElement id="kickOff_IDGenGroupElement12">
                                <smartfield:SmartField id="startDate" value="{openAt}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement13">
                                <smartfield:SmartField id="completedDate" value="{BlockProvision/completedDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement14">
                                <smartfield:SmartField id="completedBy" value="{BlockProvision/completedBy}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement15">
                                <smartfield:SmartField id="kickOffEstimatedVisitDate" value="{BlockProvision/kickOffEstimatedVisitDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement16">
                                <smartfield:SmartField id="realEndDate" value="{BlockProvision/realEndDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement17">
                                <smartfield:SmartField id="kickOffRealDate" value="{BlockProvision/kickOffRealDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement18">
                                <smartfield:SmartField id="globalStartWorksDate" value="{BlockProvision/globalStartWorksDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement19">
                                <smartfield:SmartField id="globalEndWorksDate" value="{BlockProvision/globalEndWorksDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="kickOff_IDGenGroupElement20">
                                <smartfield:SmartField id="expectedMadDate" value="{BlockProvision/expectedMadDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                    </smartform:Group>
                </smartform:groups>
            </smartform:SmartForm>
            
            <smartform:SmartForm editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}" id="kickOffCommentsFormForm">
                <smartform:layout>
                    <smartform:ColumnLayout id="kickOffCommentsFormFormColumnLayout" columnsM="1" columnsL="1" columnsXL="1" labelCellsLarge="12"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="kickOffCommentsFormFormGroup">                
                        <smartform:GroupElement id="kickOffCommentsFormFormGroupElement">
                            <smartfield:SmartField id="kickOffCommentsConfig" value="{comments}" change="onFieldChange" app:multiLineSettings="{cols: 2000, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group>                
                </smartform:groups>
            </smartform:SmartForm>
            <core:ComponentContainer id="kickOffChecklist" usage="checklist"
                name="prvintprojectsui5.components.checklist"
                component="prvintprojectsui5.components.checklist"
                visible="{= ${checklistVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="kickOffWorks" usage="works"
                name="prvintprojectsui5.components.works"
                component="prvintprojectsui5.components.works"
                propagateModel="true"
                visible="{= ${worksVisibleVF} === true}"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="kickOffApprovalFlow" usage="approvalFlow"
                name="prvintprojectsui5.components.approvalFlow"
                component="prvintprojectsui5.components.approvalFlow"
                visible="{= ${dpbVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="kickOffUploadTable" usage="uploadTable"
                name="prvintprojectsui5.components.uploadTable"
                component="prvintprojectsui5.components.uploadTable"
                propagateModel="true"
                height="100%"
                width="100%"  

                >
            </core:ComponentContainer>

        </content>
    </Panel>              
</mvc:View>