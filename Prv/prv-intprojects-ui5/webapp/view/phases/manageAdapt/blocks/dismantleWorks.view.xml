<mvc:View
    controllerName="prvintprojectsui5.controller.phases.manageAdapt.blocks.dismantleWorks"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:upload="sap.m.upload"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:layout="sap.ui.layout" 
    xmlns:table="sap.ui.table"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"  
    displayBlock="true">

    <Panel width="auto" visible="{=${configuration>/processInfo/manageAdapt/dismantleWorks/VISIBLE_ON} === 'X'}" expandable="true" expanded="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS}}" id="dismantleWorksPanel" class="sapUiResponsiveMargin">
        <headerToolbar>
            <OverflowToolbar id="dismantleWorksToolbar" design="Transparent" class="sapMShowEmpty-CTX">
                <Title id="dismantleWorksTitle" text="{i18n>dismantleWorks}"/>
                <ToolbarSpacer id="dismantleWorks_IDGenToolbarSpacer3"/>
                <smartfield:SmartLabel id="dismantleWorks_IDGenSmartLabel" labelFor="selectAssignedResponsible"/>
                <smartfield:SmartField id="selectAssignedResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/assignedResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="dismantleWorks_IDGenSmartLabel1" labelFor="selectSucontractorResponsible"/>
                <smartfield:SmartField id="selectSucontractorResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/subcontractorType}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onSubcoTypeChange"/>
                <smartfield:SmartLabel id="dismantleWorks_IDGenSmartLabel2" labelFor="selectExternalResponsible"/>
                <smartfield:SmartField id="selectExternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/externalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="dismantleWorks_IDGenSmartLabel3" labelFor="selectInternalResponsible"/>
                <smartfield:SmartField id="selectInternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/internalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" textInEditModeSource="ValueListNoValidation"/>
                <ToolbarSpacer id="dismantleWorks_IDGenToolbarSpacer5"/>
                <Switch id="dismantleWorks_IDGenSwitch"  customTextOn=" " customTextOff=" "  state="{activated}" visible="{= ${mandatory} !== 'X'}" change="onActiveChange" enabled="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/dismantleWorks/activate} === true }"/>
                <Button id="closeBlockdismantleWorks" press="onCloseBlock" text="{i18n>complete}" visible="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/dismantleWorks/complete} === true}"/>
                <OverflowToolbarButton id="buttondismantleWorksForm" press="onEditBlock" icon="sap-icon://edit" enabled="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}"  visible="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/manageAdapt/dismantleWorks/reopen} === true}"/>
                <ObjectStatus id="dismantleWorks_IDGenObjectStatus1" text="{BlockStatus/name}" state="{path: 'status', formatter:'.statusStateFormatter'}" icon="{path:'status', formatter: '.statusIconFormatter' }"/>                
            </OverflowToolbar>
        </headerToolbar>
        <content>
            <smartform:SmartForm id="dismantleWorksForm" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}">
                <smartform:layout>
                    <smartform:ColumnLayout id="dismantleWorks_IDGenColumnLayout1" columnsM="2" columnsL="3" columnsXL="6" labelCellsLarge="2"/>
                </smartform:layout>
                <smartform:groups> 
                    <smartform:Group id="dismantleWorks_IDGenGroup1" >
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement12">
                                <smartfield:SmartField id="startDate" value="{openAt}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement13">
                                <smartfield:SmartField id="completedDate" value="{BlockProvision/completedDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement14">
                                <smartfield:SmartField id="completedBy" value="{BlockProvision/completedBy}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement15">
                                <smartfield:SmartField id="expectedStartDate" value="{BlockProvision/expectedStartDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement16">
                                <smartfield:SmartField id="expectedEndDate" value="{BlockProvision/expectedEndDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement17">
                                <smartfield:SmartField id="realStartDate" value="{BlockProvision/realStartDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement18">
                                <smartfield:SmartField id="realEndDate" value="{BlockProvision/realEndDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="dismantleWorks_IDGenGroupElement19">
                                <smartfield:SmartField id="description" value="{BlockProvision/description}" change="onFieldChange"/>
                        </smartform:GroupElement>
                    </smartform:Group>
                </smartform:groups>
            </smartform:SmartForm>
            
            <smartform:SmartForm editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}" id="dismantleWorksCommentsFormForm">
                <smartform:layout>
                    <smartform:ColumnLayout id="dismantleWorksCommentsFormFormColumnLayout" columnsM="1" columnsL="1" columnsXL="1" labelCellsLarge="12"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="dismantleWorksCommentsFormFormGroup">                
                        <smartform:GroupElement id="dismantleWorksCommentsFormFormGroupElement">
                            <smartfield:SmartField id="dismantleWorksCommentsConfig" value="{comments}" change="onFieldChange" app:multiLineSettings="{cols: 2000, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group>                
                </smartform:groups>
            </smartform:SmartForm>
            <core:ComponentContainer id="dismantleWorkChecklist" usage="checklist"
                name="prvintprojectsui5.components.checklist"
                component="prvintprojectsui5.components.checklist"
                visible="{= ${checklistVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="dismantleWorksWorks" usage="works"
                name="prvintprojectsui5.components.works"
                component="prvintprojectsui5.components.works"
                propagateModel="true"
                visible="{= ${worksVisibleVF} === true}"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="dismantleWorksApprovalFlow" usage="approvalFlow"
                name="prvintprojectsui5.components.approvalFlow"
                component="prvintprojectsui5.components.approvalFlow"
                visible="{= ${dpbVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="dismantleWorksUploadTable" usage="uploadTable"
                name="prvintprojectsui5.components.uploadTable"
                component="prvintprojectsui5.components.uploadTable"
                propagateModel="true"
                height="100%"
                width="100%"  

                >
            </core:ComponentContainer>

        </content>
    </Panel>              
</mvc:View>