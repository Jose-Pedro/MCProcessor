<mvc:View
    controllerName="prvintprojectsui5.controller.phases.siteSurvey.blocks.globalResult"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:upload="sap.m.upload"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:layout="sap.ui.layout" 
    xmlns:table="sap.ui.table"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"  
    displayBlock="true">

    <Panel width="auto" visible="{=${configuration>/processInfo/siteSurvey/globalResult/VISIBLE_ON} === 'X'}" expandable="true" expanded="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS}}" id="siteSurveyglobalResultPanel" class="sapUiResponsiveMargin">
        <headerToolbar>
            <OverflowToolbar id="siteSurveyglobalResultToolbar" design="Transparent" class="sapMShowEmpty-CTX">
                <Title id="siteSurveyglobalResultTitle" text="{i18n>globalResultrecapitulatif}"/>
                <ToolbarSpacer id="globalResult_IDGenToolbarSpacer3"/>
                <smartfield:SmartLabel id="globalResult_IDGenSmartLabel" labelFor="selectAssignedResponsible"/>
                <smartfield:SmartField id="selectAssignedResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/assignedResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="globalResult_IDGenSmartLabel1" labelFor="selectSucontractorResponsible"/>
                <smartfield:SmartField id="selectSucontractorResponsible" width="8rem" fetchValueListReadOnly="true" value="{BlockProvision/subcontractorType}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onSubcoTypeChange"/>
                <smartfield:SmartLabel id="globalResult_IDGenSmartLabel2" labelFor="selectExternalResponsible"/>
                <smartfield:SmartField id="selectExternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/externalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" />
                <smartfield:SmartLabel id="globalResult_IDGenSmartLabel3" labelFor="selectInternalResponsible"/>
                <smartfield:SmartField id="selectInternalResponsible" fetchValueListReadOnly="true" value="{BlockProvision/internalResponsible}" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" change="onFieldChange" textInEditModeSource="ValueListNoValidation"/>
                <ToolbarSpacer id="globalResult_IDGenToolbarSpacer5"/>
                <Switch id="globalResult_IDGenSwitch"  customTextOn=" " customTextOff=" "  state="{activated}" visible="{= ${mandatory} !== 'X'}" change="onActiveChange" enabled="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/siteSurvey/globalResult/activate} === true }"/>
                <Button id="closeBlockglobalResult" press="onCloseBlock" text="{i18n>complete}" visible="{= (${status} === ${configuration>/constants/BLOCK_NOTINITIALIZED} || ${status} === ${configuration>/constants/BLOCK_INPROGRESS} ) &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/siteSurvey/globalResult/complete} === true}"/>
                <OverflowToolbarButton id="buttonglobalResultForm" press="onEditBlock" icon="sap-icon://edit" enabled="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}"  visible="{= ${status} === ${configuration>/constants/BLOCK_COMPLETED} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true &amp;&amp; ${configuration>/blockActions/siteSurvey/globalResult/reopen} === true}"/>
                <ObjectStatus id="globalResult_IDGenObjectStatus1" text="{BlockStatus/name}" state="{path: 'status', formatter:'.statusStateFormatter'}" icon="{path:'status', formatter: '.statusIconFormatter' }"/>                
            </OverflowToolbar>
        </headerToolbar>
        <content>
            <smartform:SmartForm id="siteSurveyglobalResultForm" editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}">
                <smartform:layout>
                    <smartform:ColumnLayout id="siteSurveyglobalResult_IDGenColumnLayout1" columnsM="2" columnsL="3" columnsXL="6" labelCellsLarge="2"/>
                </smartform:layout>
                <smartform:groups> 
                    <smartform:Group id="siteSurveyglobalResult_IDGenGroup1" >
                        <smartform:GroupElement id="siteSurveyglobalResult_IDGenGroupElement12">
                                <smartfield:SmartField id="siteSurveyglobalResultstartDate" value="{openAt}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="siteSurveyglobalResult_IDGenGroupElement13">
                                <smartfield:SmartField id="siteSurveyglobalResultcompletedDate" value="{BlockProvision/completedDate}" change="onFieldChange"/>
                        </smartform:GroupElement>
                        <smartform:GroupElement id="globalResult_IDGenGroupElement14">
                                <smartfield:SmartField id="complexity" value="{BlockProvision/complexity}" change="onFieldChange"/>
                        </smartform:GroupElement>
                    </smartform:Group>
                </smartform:groups>
            </smartform:SmartForm>
            <smartform:SmartForm editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}" id="siteSurveyglobalResultCommentsFormForm">
                <smartform:layout>
                    <smartform:ColumnLayout id="siteSurveyglobalResultCommentsFormFormColumnLayout" columnsM="1" columnsL="1" columnsXL="1" labelCellsLarge="12"/>
                </smartform:layout>
                <smartform:groups>
                    <smartform:Group id="siteSurveyglobalResultCommentsFormFormGroup">                
                        <smartform:GroupElement id="siteSurveyglobalResultCommentsFormFormGroupElement">
                            <smartfield:SmartField id="siteSurveyglobalResultCommentsConfig" value="{comments}" change="onFieldChange" app:multiLineSettings="{cols: 2000, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group>                
                </smartform:groups>
            </smartform:SmartForm>
            <core:ComponentContainer id="siteSurveyGlobalResultChecklist" usage="checklist"
                name="prvintprojectsui5.components.checklist"
                component="prvintprojectsui5.components.checklist"
                visible="{= ${checklistVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="siteSurveyGlobalResultWorks" usage="works"
                name="prvintprojectsui5.components.works"
                component="prvintprojectsui5.components.works"
                propagateModel="true"
                visible="{= ${worksVisibleVF} === true}"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <core:ComponentContainer id="siteSurveyGlobalResultApprovalFlow" usage="approvalFlow"
                name="prvintprojectsui5.components.approvalFlow"
                component="prvintprojectsui5.components.approvalFlow"
                visible="{= ${dpbVisibleVF} === true}"
                propagateModel="true"
                height="100%"
                width="100%" >
            </core:ComponentContainer>
            <smarttable:SmartTable 
                id="impactedCustomersTable" 
                tableType="Table"
                header="{i18n>impactedCustomers}"
                entitySet="ImpactedCustomers"
                tableBindingPath="ImpactedCustomers"
                width="100%" 
                direction="Column" 
                fitContainer="true" 
                placeToolbarInTable="true" 
                persistencyKey="changeLogTable" 
                beforeRebindTable="onBeforeRebindTable"
                app:useSmartField="true"
                showPasteButton="false"
                enableCopy="false"
                enableAutoColumnWidth="true" 
                enableAutoBinding="true"
                fieldChange="onFieldChange"
                editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${configuration>/editMode} === true}"
                requestAtLeastFields="ID,impacted">
                <table:Table id="impactedCustomersInternalTable" rowMode="Auto" selectionMode="None" >
                    <table:rowMode>
                        <rowmodes:Interactive id="impactedCustomersTableRowMode" xmlns:rowmodes="sap.ui.table.rowmodes" minRowCount="1" rowCount="3"/>
                    </table:rowMode>
                </table:Table>
            </smarttable:SmartTable>
            <core:ComponentContainer id="siteSurveyGlobalResultUploadTable" usage="uploadTable"
                name="prvintprojectsui5.components.uploadTable"
                component="prvintprojectsui5.components.uploadTable"
                propagateModel="true"
                height="100%"
                width="100%"  

                >
            </core:ComponentContainer>

        </content>
    </Panel>              
</mvc:View>