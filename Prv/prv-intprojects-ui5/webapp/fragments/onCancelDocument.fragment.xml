<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:customdata="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
	xmlns:smartform="sap.ui.comp.smartform"
    xmlns:smartfield="sap.ui.comp.smartfield"
    displayBlock="true">
    <Dialog id="onCancelDocumentDialog" title="{i18n>onCancelDocument}" >
        <content>
	        <smartform:SmartForm id="onCancelDocumentForm" editable="true" >
                <smartform:groups> 
                    <smartform:Group id="_IDGenGroup3" >
                        <smartform:GroupElement id="_IDGenGroupElement10">
                            <smartfield:SmartField id="cancellationReason1" value='{cancellationReason}' entitySet="Blocks"  customdata:multiLineSettings="{cols: 60, rows: 5}"/>
                        </smartform:GroupElement>
                    </smartform:Group >
                </smartform:groups> 
            </smartform:SmartForm>
        </content>
        <footer>
			<Toolbar id="_IDGenToolbar9">
				<content>
					<Button id="onCancelDocumentPopupBtn"
						visible="{= ${message>/}.length > 0}"
                        icon="sap-icon://message-popup"
                        type="Neutral"
						text="{= ${message>/}.length }"
						press="onMessagePopoverPress" />
					<ToolbarSpacer id="_IDGenToolbarSpacer20" />
					<Button id="confirmOnCancelDocument"
                            type="Emphasized"
							text="{i18n>confirm}"
							press="confirmOnCancelDocument" />

					<Button 
                        id="cancelOnCancelCancelDocumentBtn"
                        text="{i18n>cancel}"
                        type="Transparent"
                        press="onCloseDialog"
                    >
                        <customData>
                            <core:CustomData key="dialogName" value="_oCancelDocument" />
                        </customData>
                    </Button>
				</content>
			</Toolbar>        
        </footer>
    </Dialog>
</core:FragmentDefinition>