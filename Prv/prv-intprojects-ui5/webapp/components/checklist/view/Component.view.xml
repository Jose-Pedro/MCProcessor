<mvc:View 
    xmlns:core="sap.ui.core"
    controllerName="prvintprojectsui5.components.checklist.controller.Component"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartField="sap.ui.comp.smartfield"
    xmlns:table="sap.ui.table"
    xmlns:m="sap.m"
    xmlns:customdata="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    displayBlock="true">
    <smartTable:SmartTable
        id="checklistSmartable"
        header="{i18n>checklist}"
        entitySet="ChecklistItems"
        tableBindingPath="Checklist"
        tableType="Table"
        enableAutoBinding="false"
        fitContainer="true" 
        width="100%"
        direction="Column"
        editable="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}"
        editTogglable="false"
        showPasteButton="false"
        enableCopy="false"
        beforeRebindTable="onBeforeRebindTable"
        useTablePersonalisation="false"
        requestAtLeastFields="ID,description,type_ID,booleanValue,stringValue,dateValue,integerValue,decimalValue,pickList,booleanValueFC,stringValue,dateValueFC,integerValueFC,decimalValueFC,pickListFC,rowStatus"
        customdata:useSmartField="true">
        <smartTable:customToolbar>
            <m:OverflowToolbar id="checklistTableToolbar" design="Transparent">
                <m:ToolbarSpacer id="checkListTableToolbar1"/>
                <m:Button id="checklistTableToolbarBtnAdd" text="{i18n>create}" type="Emphasized" press="onCreateItem" enabled="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${activated} === true &amp;&amp; ${configuration>/editMode} === true}" visible="{= ${configuration>/editMode} === true}"/>
                <!-- <m:Button id="checklistTableToolbarBtnDelete" text="{i18n>delete}" type="Ghost" press="onDeleteItems" enabled = "false"/> -->
            </m:OverflowToolbar>
        </smartTable:customToolbar>
        <table:Table id="checklistInnerTable"
            rowsUpdated="onRowsUpdated"
            fixedColumnCount="2"
            rowActionCount="1"
            selectionMode="None" >
            <table:rowSettingsTemplate>
				<table:RowSettings highlight="{rowStatus}" />
			</table:rowSettingsTemplate>
            <table:Column width="40rem">
                <m:Label id="checklistItemName" text="{i18n>itemName}" />
                <table:customData>
                    <core:CustomData key="p13nData" value='\{"columnKey": "description", "leadingProperty":"description", "columnIndex" : "1"}' />
                </table:customData>
                <table:template>
                    <smartField:SmartField value="{description}"/>
                </table:template>
            </table:Column>
            <table:Column width="50rem">
                <m:Label id="checklistItemValue" text="{i18n>itemValue}" />
                <table:customData>
                    <core:CustomData key="p13nData" value='\{"columnKey": "integerValue", "leadingProperty":"integerValue", "columnIndex" : "2"}' />
                </table:customData>
                <table:template>
                    <m:HBox>
                        <smartField:SmartField value="{booleanValue}" change="onFieldChange" />
                        <smartField:SmartField value="{stringValue}" change="onFieldChange" />
                        <smartField:SmartField value="{dateValue}" change="onFieldChange" />
                        <smartField:SmartField value="{integerValue}" change="onFieldChange" />
                        <smartField:SmartField value="{decimalValue}" change="onFieldChange" />
                        <smartField:SmartField value="{pickList}" change="onFieldChange" />
                    </m:HBox>
                </table:template>
            </table:Column>
            <table:rowActionTemplate>
                <table:RowAction>
                    <table:items>
                        <table:RowActionItem icon="sap-icon://decline" text="{i18n>cancel}" press="onDeleteItem" visible="{editable}"/>
                    </table:items>
                </table:RowAction>
            </table:rowActionTemplate>
            <table:rowMode>
                <rowmodes:Interactive id="_IDGenInteractive"
                    xmlns:rowmodes="sap.ui.table.rowmodes"
                    minRowCount="1"
                    rowCount="4"
                />
            </table:rowMode>
        </table:Table>
    </smartTable:SmartTable>

</mvc:View>