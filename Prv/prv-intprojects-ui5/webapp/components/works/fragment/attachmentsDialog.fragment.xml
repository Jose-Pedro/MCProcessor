<core:FragmentDefinition
    width="5%"
    height="5%"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartfield="sap.ui.comp.smartfield"
    xmlns:table="sap.ui.table"
    xmlns:upload="sap.m.upload"
    xmlns:customdata="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    displayBlock="true">
    <Dialog  id="approvalFlowAttachmentsDialog" title="{i18n>workAttachments}" showHeader="false" >
        <content>
            <Table
                id="uploadTable"
                headerText="{i18n>workAttachments}" 
                sticky="ColumnHeaders,HeaderToolbar"
                width="100%"
                mode="None"
                fixedLayout="false"
                autoPopinMode="true"
                hiddenInPopin="None"
                items="{ path: 'documents',  templateShareable: false }">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>workAttachments}" level="H2" />
                        <ToolbarSpacer />
                        <upload:ActionsPlaceholder id="uploadButton" placeholderFor="UploadButtonPlaceholder" />
                    </OverflowToolbar>
                </headerToolbar>
                <dependents>
                    <plugins.UploadSetwithTable
                        id="worksUploadPlugin"
                        multiple="true"
                        httpRequestMethod="Put"
                        uploadEnabled="{= ${status} === ${configuration>/constants/BLOCK_INPROGRESS} &amp;&amp; ${hasAuthVF} === true &amp;&amp; ${configuration>/editMode} === true}"
                        onActivated="onAttachmentTablePluginActivated"
                        uploadCompleted="onTableFileUploadCompleted"
                        itemValidationHandler=".onAttachmentUploadFileValidation"
                        cloudFilePickerEnabled="true"
                        actions="uploadButton" >
                        <rowConfiguration>
                            <upload.UploadItemConfiguration fileNamePath="fileName" mediaTypePath="mediaType" />
                        </rowConfiguration>
                    </plugins.UploadSetwithTable>
                </dependents>
                <columns>
                    <Column width="3rem"/>
                    <Column><header><Label text="{i18n>filename}" /></header></Column>
                    <Column width="3rem"/>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <core:Icon class="sapMUSTItemImage sapMUSTItemIcon" src="{ parts: ['mediaType', 'documentName'], formatter: '.getTableFileIcon'  }" />
                            <Link text="{documentName}" press="onTableFileDownload" class="sapUiTinyMarginBottom"/>
                            <!-- <Text text="{documentTypeName}"/> -->
                            <Button icon="sap-icon://decline" tooltip="{i18n>DeleteFile}" press="onTableFileRemove" type="Transparent" class="sapUiTinyMarginBegin"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>            
        </content>
        <footer>
			<Toolbar>
				<content>
					<Button id="onWorkAttachmentMessagesBtn"
						visible="{= ${message>/}.length > 0}"
                        icon="sap-icon://message-popup"
                        type="Neutral"
						text="{= ${message>/}.length }"
						press="onMessagePopoverPress" />                    
					<ToolbarSpacer />
					<Button  type="Transparent" text="{i18n>close}" press="onCloseWorkAttachments" />
				</content>
			</Toolbar>        
        </footer>
    </Dialog>
</core:FragmentDefinition>