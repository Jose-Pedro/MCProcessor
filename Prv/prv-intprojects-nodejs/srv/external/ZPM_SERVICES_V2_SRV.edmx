<Property Name="isDeleted" Type="Edm.Boolean" Nullable="false" sap:label="Delete indicator"/>
</EntityType>
<EntityType Name="serviceRelationType" sap:content-version="1">
<Key>
<PropertyRef Name="relationTypeId"/>
</Key>
<Property Name="relationTypeId" Type="Edm.String" Nullable="false" MaxLength="2" sap:label="RelType"/>
<Property Name="relationTypeDescription" Type="Edm.String" Nullable="false" MaxLength="20" sap:label="RelTypeDes"/>
</EntityType>
<EntityType Name="tarificationTool" sap:content-version="1">
<Key>
<PropertyRef Name="serviceId"/>
<PropertyRef Name="siteId"/>
<PropertyRef Name="commercialElementId"/>
<PropertyRef Name="priceBookEntry"/>
</Key>
<Property Name="serviceId" Type="Edm.String" Nullable="false" MaxLength="15"/>
<Property Name="siteId" Type="Edm.String" Nullable="false" MaxLength="30" sap:label="Functional loc."/>
<Property Name="commercialElementId" Type="Edm.String" Nullable="false" MaxLength="36"/>
<Property Name="commercialElementDescription" Type="Edm.String" Nullable="false" MaxLength="500"/>
<Property Name="priceBookEntry" Type="Edm.String" Nullable="false" MaxLength="36"/>
<Property Name="alias" Type="Edm.String" Nullable="false" MaxLength="500"/>
<Property Name="priceBookName" Type="Edm.String" Nullable="false" MaxLength="255"/>
<Property Name="priceBookCode" Type="Edm.String" Nullable="false" MaxLength="15"/>
<Property Name="commercialElementCode" Type="Edm.String" Nullable="false" MaxLength="15"/>
</EntityType>
<ComplexType Name="terminationReason">
<Property Name="key" Type="Edm.String" MaxLength="2" sap:label="Status reason"/>
<Property Name="description" Type="Edm.String" MaxLength="255" sap:label="Comments"/>
</ComplexType>
<ComplexType Name="nextOpStatus">
<Property Name="plant" Type="Edm.String" MaxLength="4" sap:label="Planning plant"/>
<Property Name="fromStatusId" Type="Edm.String" MaxLength="4" sap:label="Status ID"/>
<Property Name="fromStatusDescription" Type="Edm.String" MaxLength="60" sap:label="Short Descript."/>
<Property Name="toStatusId" Type="Edm.String" MaxLength="4" sap:label="Status ID"/>
<Property Name="toStatusDescription" Type="Edm.String" MaxLength="60" sap:label="Short Descript."/>
<Property Name="isInitialStatus" Type="Edm.Boolean" sap:label="TRUE"/>
<Property Name="isAutoTransitionActive" Type="Edm.Boolean" sap:label="TRUE"/>
</ComplexType>
<ComplexType Name="boolean">
<Property Name="boole" Type="Edm.Boolean" sap:label="TRUE"/>
</ComplexType>
<ComplexType Name="serviceUpdateMessage">
<Property Name="ServiceId" Type="Edm.String" MaxLength="15" sap:label="Intern id"/>
<Property Name="UpdateFlag" Type="Edm.Boolean" sap:label="Boolean Variable (X=true, -=false, space=unknown)"/>
<Property Name="Message" Type="Edm.String" sap:label="STR_LIGHT"/>
</ComplexType>
