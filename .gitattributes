# Normalize line endings: store LF in repo, convert to platform-native on checkout.
* text=auto eol=lf

# Explicit text: code and config
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.md        text eol=lf
*.cds       text eol=lf
*.hdbcds    text eol=lf
*.hdbview   text eol=lf
*.hdbprocedure text eol=lf
*.hdbtable  text eol=lf
*.hdbsequence text eol=lf
*.hdbsynonym text eol=lf
*.hdbtabledata text eol=lf
*.hdbcalculationview text eol=lf
*.sql       text eol=lf
*.properties text eol=lf
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.sh        text eol=lf

# Explicit binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.mtar      binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
